ric:zeromatrix(dim,dim)$
ricci(false)$
for i thru dim do for j:i thru dim do
  if ric[i,j]≠0 then
    ishow('R([ξ[i],ξ[j]])=factor(ric[i,j]))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
map(ldisp,efe:findde(ric,2))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
solve(eliminate(efe,[diff(a,t,2)]),diff(a,t));
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
uric:zeromatrix(dim,dim)$
uricci(false)$
for i thru dim do for j:i thru dim do
  if uric[i,j]≠0 then
    ishow('R([],[ξ[i],ξ[j]])=factor(uric[i,j]))$
