TeX:

\textbf{Generic Connection 1-form} $\omega$

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
kill(labels,ω,Θ,Ω)$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
A:[a_1,a_2,a_3,a_4]$
B:[b_1,b_2,b_3,b_4]$
C:[c_1,c_2,c_3,c_4]$
D:[d_1,d_2,d_3,d_4]$
E:[e_1,e_2,e_3,e_4]$
F:[f_1,f_2,f_3,f_4]$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
ω:zeromatrix(dim,dim)$
ω[1,2]:-ω[2,1]:A.cartan_basis$
ω[1,3]:-ω[3,1]:B.cartan_basis$
ω[1,4]:-ω[4,1]:C.cartan_basis$
ω[2,3]:-ω[3,2]:D.cartan_basis$
ω[2,4]:-ω[4,2]:E.cartan_basis$
ω[3,4]:-ω[4,3]:F.cartan_basis$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

$\Theta^a=\omega_b^a\wedge\sigma^b$

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
block([matrix_element_mult:"~"],
  Θ:list_matrix_entries(expand(ω.σ)))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Cartan's First structural equation}:
$\mathrm{d}e^{\hat\alpha}+\omega_{\hat\beta}^{\hat\alpha}\wedge
e^{\hat\beta}=0$

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
Eq:zeromatrix(dim,dim)$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
for i thru dim do for j thru dim do
Eq[i,j]:format(coeff(coeff(dσ,cartan_basis[i]),cartan_basis[j])=
coeff(coeff(-Θ,cartan_basis[i]),cartan_basis[j]),%list)$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
Eqs:apply('append,list_matrix_entries(Eq))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
linsol:linsolve(Eqs,append(A,B,C,D,E,F))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
ldisplay(Θ:at(Θ,linsol))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
is(dσ=-Θ);
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Update Connection 1-form} $\omega$

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
ldisplay(ω:at(ω,linsol))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
for i thru dim do for j:i thru dim do
  if ω[i,j]≠0 then
    ishow('ω([" ",ξ[i]],[ξ[j]])=trigsimp(ω[i,j]))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Update Connection 2-form} $\mathrm{d}\omega$

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
ldisplay(dω:trigsimp(matrixmap(edit,ext_diff(ω))))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Update coefficients}

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
ldisplay(A:at(A,linsol))$
ldisplay(B:at(B,linsol))$
ldisplay(C:at(C,linsol))$
ldisplay(D:at(D,linsol))$
ldisplay(E:at(E,linsol))$
ldisplay(F:at(F,linsol))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Cartan's Second structural equation}:
$R_{\hat\beta}^{\hat\alpha}=\mathrm{d}\omega_{\hat\beta}^{\hat\alpha}
+\omega_{\hat\gamma}^{\hat\alpha}\wedge
\omega_{\hat\beta}^{\hat\gamma}$

   [wxMaxima: comment end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Curvature 2-form} $\Omega$
\begin{equation}
R^a_{\hphantom{a}b}=\mathrm{d}\omega^a_{\hphantom{a}b}+
\omega^a_{\hphantom{a}c}\wedge\omega^c_{\hphantom{c}b}
\notag
\end{equation}

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
block([matrix_element_mult:"~"],
  ldisplay(Ω:trigsimp(matrixmap(edit,dω+ω.ω))))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
for i thru dim do for j:i thru dim do
  if ω[i,j]≠0 then
    ishow('Ω([" ",ξ[i]],[ξ[j]])=trigsimp(Ω[i,j]))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Forms in terms of the coframe}

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
Eqs:makelist(o[ξ[i]]=σ[i],i,1,cartan_dim)$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
Eqs:ishow(makelist(o([],[ξ[i]])=σ[i],i,1,cartan_dim))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
linsolc:ishow(linsolve(Eqs,cartan_basis))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Connection 1-form} $\omega$

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
ishow(ev(ω,linsolc,fullratsimp))$
/* [wxMaxima: input   end   ] */

