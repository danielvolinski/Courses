/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Cartan Structure equations}

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
Nilpotency:makelist(del(k)²=0,k,ξ);
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
TT:subst(Nilpotency,genmatrix(lambda([i,j],thi[i].thi[j]),dim,dim));
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
DD:genmatrix(lambda([i,j],diff(Omega[i,j])),dim,dim);
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Verify First structure equation (torsion-free)}

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
list_matrix_entries(subst(Nilpotency,Omega.thi));
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
list_matrix_entries(diff(thi));
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Second structure equation (curvature)}

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
subst(Nilpotency,diff(Omega)+Omega.Omega);
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{The Killing equations}

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
