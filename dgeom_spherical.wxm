\notag
\end{equation}

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
block([matrix_element_mult:"~"],
  ldisplay(Ω:matrixmap(edit,dω+ω.ω)))$
/* [wxMaxima: input   end   ] */

