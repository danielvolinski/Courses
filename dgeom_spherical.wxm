/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
trigsimp(A.transpose(A));
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{The connection coefficients}

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
