/* [wxMaxima: input   start ] */
init_cartan(ξ)$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
ldisplay(cartan_basis,cartan_coords,cartan_dim,extdim)$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Coframe} $\sigma$

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
ldisplay(σ:list_matrix_entries(√(lg).cartan_basis))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Exterior derivative of the coframe} $\mathrm{d}\sigma$

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
ldisplay(dσ:ext_diff(σ))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Generic Connection 1-form} $\omega$

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
A:[a_1,a_2,a_3]$
B:[b_1,b_2,b_3]$
C:[c_1,c_2,c_3]$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
ω:zeromatrix(dim,dim)$
ω[1,2]:-ω[2,1]:A.cartan_basis$
ω[1,3]:-ω[3,1]:B.cartan_basis$
ω[2,3]:-ω[3,2]:C.cartan_basis$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

$\Theta^a=\omega_b^a\wedge\sigma^b$

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
block([matrix_element_mult:"~"],
  Θ:list_matrix_entries(expand(ω.σ)))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Cartan's First structure equation (torsion-free)}:
$\mathrm{d}e^{\hat\alpha}+\omega_{\hat\beta}^{\hat\alpha}\wedge
e^{\hat\beta}=0$

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
Eq:zeromatrix(dim,dim)$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
for i thru dim do for j thru dim do
Eq[i,j]:format(coeff(coeff(dσ,cartan_basis[i]),cartan_basis[j])=
coeff(coeff(-Θ,cartan_basis[i]),cartan_basis[j]),%list)$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
Eqs:apply('append,list_matrix_entries(Eq))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
linsol:linsolve(Eqs,append(A,B,C));
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
ldisplay(Θ:at(Θ,linsol))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
is(dσ=-Θ);
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Update Connection 1-form} $\omega$

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
ldisplay(ω:at(ω,linsol))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Verify First structure equation}

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
ldisplay(σ,dσ)$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: input   start ] */
block([matrix_element_mult:"~"],
  ldisplay(Θ:list_matrix_entries(expand(ω.σ))))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Update Connection 2-form} $\mathrm{d}\omega$

   [wxMaxima: comment end   ] */

/* [wxMaxima: input   start ] */
ldisplay(dω:trigsimp(matrixmap(edit,ext_diff(ω))))$
/* [wxMaxima: input   end   ] */

/* [wxMaxima: comment start ]
TeX:

\textbf{Cartan's Second structure equation (curvature)}:
$R_{\hat\beta}^{\hat\alpha}=\mathrm{d}\omega_{\hat\beta}^{\hat\alpha}
